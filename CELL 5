import torch

# Re-enable fast inference kernels
FastLanguageModel.for_inference(model)

def generate_cleaning_code(messy_description, max_new_tokens=1024, temperature=0.1):
    """
    Takes a messy schema description, formats it with the Llama-3 chat
    template, runs model.generate(), and prints ONLY the Pandas code.
    """
    messages = [{"role": "user", "content": messy_description}]

    inputs = tokenizer.apply_chat_template(
        messages,
        tokenize              = True,
        add_generation_prompt = True,             # appends assistant header
        return_tensors        = "pt",
    ).to("cuda")

    with torch.no_grad():
        outputs = model.generate(
            input_ids       = inputs,
            max_new_tokens  = max_new_tokens,
            use_cache       = True,
            do_sample       = True,
            temperature     = temperature,        # low temp → deterministic code
            top_p           = 0.95,
            pad_token_id    = tokenizer.eos_token_id,
        )

    # Decode ONLY the newly-generated tokens (skip the input prompt)
    input_length  = inputs.shape[1]
    generated_ids = outputs[0][input_length:]
    response      = tokenizer.decode(generated_ids, skip_special_tokens=True).strip()

    print("=" * 80)
    print("MESSY SCHEMA INPUT:")
    print(messy_description)
    print("-" * 80)
    print("GENERATED PANDAS CODE:")
    print("-" * 80)
    print(response)
    print("=" * 80 + "\n")
    return response


