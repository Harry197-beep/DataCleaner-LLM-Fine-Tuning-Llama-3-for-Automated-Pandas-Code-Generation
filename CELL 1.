# Step 5: Verify everything is coherent BEFORE importing unsloth
import importlib, subprocess
def show(pkg):
    try:
        m = importlib.import_module(pkg)
        return getattr(m, "__version__", "unknown")
    except Exception as e:
        return f"IMPORT FAILED: {e}"

print("Pre-import check:")
print(f"  torch:          {show('torch')}")
print(f"  triton:         {show('triton')}")
print(f"  transformers:   {show('transformers')}")
print(f"  trl:            {show('trl')}")
print(f"  peft:           {show('peft')}")
print(f"  bitsandbytes:   {show('bitsandbytes')}")
